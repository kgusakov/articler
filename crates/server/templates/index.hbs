<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Articler</title>
  <link rel="icon" type="image/x-icon" href="/static/images/favicon.ico">
  <link rel="stylesheet" href="/static/css/main.css">
  <script src="/static/js/htmx.min.js"></script>
</head>

<body class="bg-white text-primary">
  <!-- Header -->
  <header class="h-[72px] px-4 md:px-8 lg:px-[120px] flex items-center justify-between border-b border-surface">
    <a href="/" class="flex items-center gap-3">
      <img src="/static/images/Logo.svg" />
    </a>

    {{#if nav_partial}}
    {{> (lookup this 'nav_partial') }}
    {{/if}}
  </header>

  {{> (lookup this 'main_partial') }}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const profileButton = document.getElementById('profile-menu-button');
      const profileMenu = document.getElementById('profile-menu');

      if (profileButton && profileMenu) {
        profileButton.addEventListener('click', function (e) {
          e.stopPropagation();
          profileMenu.classList.toggle('hidden');
        });

        document.addEventListener('click', function (e) {
          if (!profileButton.contains(e.target) && !profileMenu.contains(e.target)) {
            profileMenu.classList.add('hidden');
          }
        });
      }
    });
  </script>
</body>

</html>