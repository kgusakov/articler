<style>
    code {
        outline: none !important;
    }

    code::selection {
        background-color: #bfdbfe;
    }

    #copyNotification {
        transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out;
    }

    #copyNotification.show {
        opacity: 1 !important;
        transform: translateY(0) !important;
    }

</style>

<script>
    function copyToClipboard(text) {
        navigator.clipboard.writeText(text).then(() => {
            const notification = document.getElementById('copyNotification');
            notification.classList.add('show');
            setTimeout(() => {
                notification.classList.remove('show');
            }, 2000);
        });
    }
</script>

<div class="w-full">
    <div class="flex items-center justify-between mb-8">
        <h1 class="text-3xl font-light">OAuth Clients</h1>
    </div>

    <!-- Create Form -->
    <form method="post" action="/do_create_client" class="flex gap-3 mb-8 pb-8 border-b">
        <input type="text" name="client_name" placeholder="Client name"
            class="input-underline flex-1 px-4 py-2 border-border focus:border-primary">
        <button type="submit" class="btn-outline">
            Create
        </button>
    </form>

    <!-- Clients -->
    <div class="space-y-1">
        {{#each clients}}
        <details class="group">
            <summary class="px-4 py-3 cursor-pointer hover:bg-gray-100 flex justify-between items-center list-none">
                <span class="font-medium">{{client_name}}</span>
                <span class="text-gray-400 group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="px-4 py-4 bg-gray-50 grid gap-3">
                <div class="flex items-center gap-2">
                    <span class="text-xs uppercase text-gray-500 w-24">Client ID</span>
                    <code
                        class="flex-1 text-sm bg-gray-100 px-2 py-1 border border-gray-300 text-gray-700 select-text ">{{client_id}}</code>
                    <button onclick="copyToClipboard('{{client_id}}')" class="btn-copy">
                        Copy
                    </button>
                </div>
                <div class="flex items-center gap-2">
                    <span class="text-xs uppercase text-gray-500 w-24">Secret</span>
                    <code
                        class="flex-1 text-sm bg-gray-100 px-2 py-1 border border-gray-300 text-gray-700 select-text ">{{client_secret}}</code>
                    <button onclick="copyToClipboard('{{client_secret}}')" class="btn-copy">
                        Copy
                    </button>
                </div>
                <div class="flex justify-end pt-2">
                    <button type="button" class="btn-danger"
                        _="on click
                            set #deleteClientName.textContent to '{{client_name}}'
                            set #deleteClientId.value to '{{id}}'
                            call #deleteDialog.showModal()">
                        Delete
                    </button>
                </div>
            </div>
        </details>
        {{/each}}
    </div>
</div>

<!-- Delete Confirmation Dialog -->
<dialog id="deleteDialog" class="dialog-modal">
    <form method="post" action="/do_client_delete">
        <input type="hidden" id="deleteClientId" name="id" />
        <div class="dialog-body">
            <h2 class="text-lg font-medium text-primary">Delete Client</h2>
            <p class="text-sm text-muted">
                Are you sure you want to delete <strong id="deleteClientName" class="text-primary"></strong>?
                This action cannot be undone.
            </p>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button" class="btn-outline"
                    _="on click call #deleteDialog.close()">
                    Cancel
                </button>
                <button type="submit" class="btn-danger">
                    Delete
                </button>
            </div>
        </div>
    </form>
</dialog>

<!-- Copy Notification -->
<div id="copyNotification"
    class="fixed bottom-8 left-1/2 -translate-x-1/2 px-4 py-2 bg-black text-white text-sm rounded opacity-0 transform translate-y-2 pointer-events-none">
    Copied
</div>