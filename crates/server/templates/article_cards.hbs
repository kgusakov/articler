{{#each articles}}
<article class="group">
    <div class="aspect-347/200 rounded overflow-hidden mb-4 relative"
        style="background-image: url('/static/images/NoImage.svg'); background-size: cover; background-position: center;">
        <a href="/article/{{id}}" class="block w-full h-full">
            {{#if image_url}}
            <img src="{{image_url}}" class="w-full h-full object-cover" onload="this.style.backgroundColor='white'" alt="">
            {{/if}}
        </a>
        <div class="absolute bottom-0 right-0 flex items-center gap-5 pl-5 pr-4 py-2.5 rounded-tl-lg"
            style="background: rgba(255,255,255,0.4); backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px);">
            <form method="post" action="/do_favourite" hx-post="/do_favourite" hx-target="#article-cards"
                hx-swap="morph:innerHTML" class="flex items-center" id="do_favourite_form">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="starred" value="{{#unless is_starred}}true{{else}}false{{/unless}}" />
                {{#if is_starred}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Unstar">
                    <img src="/static/images/FavoriteOn.svg" alt="Unstar" />
                </button>
                {{else}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Star">
                    <img src="/static/images/FavoriteOff.svg" alt="Star" />
                </button>
                {{/if}}
            </form>
            <form method="post" action="/do_archive" hx-post="/do_archive" hx-target="#article-cards"
                hx-swap="morph:innerHTML" id="do_archive_form" class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="archived" value="{{#unless is_archived}}true{{else}}false{{/unless}}" />
                {{#if is_archived}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Mark as unread">
                    <img src="/static/images/MarkRead.svg" alt="Mark as unread" />
                </button>
                {{else}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Mark as read">
                    <img src="/static/images/MarkUnRead.svg" alt="Mark as read" />
                </button>
                {{/if}}
            </form>
            <form method="post" action="/do_delete" hx-post="/do_delete" hx-target="#article-cards"
                hx-swap="morph:innerHTML" id="do_delete_form" class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <button class="hover:scale-110 transition-transform" title="Delete">
                    <img src="/static/images/Delete.svg" alt="Delete" />
                </button>
            </form>
        </div>
    </div>
    <a href="/article/{{id}}" class="block">
        <h3 class="font-medium leading-snug mb-2 group-hover:text-secondary cursor-pointer">{{title}}</h3>
    </a>
    <div class="flex items-center gap-2 text-xs text-muted">
        <span>{{domain}}</span>
        <span>·</span>
        <span>{{reading_time}} min read</span>
    </div>
</article>
{{/each}}