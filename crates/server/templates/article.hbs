<main id="article-page" class="max-w-3xl mx-auto px-4 md:px-8 pt-6 lg:pt-[76px] pb-8 lg:pb-12">
    <!-- Top bar -->
    <div class="flex items-center justify-between mb-8">
        <a href="javascript:history.back()"
            class="flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back
        </a>
        <div class="flex items-center gap-4">
            <form method="post" action="/do_favourite" hx-post="/do_favourite" hx-target="#article-page"
                hx-swap="morph:outerHTML" hx-vals='{"source": "{{source}}"}' class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="starred" value="{{#unless is_starred}}true{{else}}false{{/unless}}" />
                {{#if is_starred}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Unstar">
                    <img src="/static/images/FavoriteOn.svg" alt="Unstar" />
                </button>
                {{else}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Star">
                    <img src="/static/images/FavoriteOff.svg" alt="Star" />
                </button>
                {{/if}}
            </form>
            <form method="post" action="/do_archive" hx-post="/do_archive" hx-target="#article-page"
                hx-swap="morph:outerHTML" hx-vals='{"source": "{{source}}"}' class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="archived" value="{{#unless is_archived}}true{{else}}false{{/unless}}" />
                {{#if is_archived}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Mark as unread">
                    <img src="/static/images/MarkRead.svg" alt="Mark as unread" />
                </button>
                {{else}}
                <button type="submit" class="hover:scale-110 transition-transform" title="Mark as read">
                    <img src="/static/images/MarkUnRead.svg" alt="Mark as read" />
                </button>
                {{/if}}
            </form>
            <form method="post" action="/do_delete" hx-post="/do_delete" hx-target="#article-page"
                hx-swap="morph:outerHTML" hx-vals='{"source": "{{source}}"}' class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="back_location" value="/" />
                <button type="submit" class="hover:scale-110" title="Delete">
                    <img src="/static/images/Delete.svg" alt="Delete" />
                </button>
            </form>
        </div>
    </div>

    <!-- Article header -->
    <h1 class="text-3xl lg:text-4xl font-bold leading-tight mb-4">{{title}}</h1>
    <div class="flex items-center gap-2 text-sm text-muted mb-8 pb-8 border-b border-border">
        <a href="{{url}}" target="_blank" rel="noopener noreferrer"
            class="hover:text-primary transition-colors underline">{{domain}}</a>
        <span>&middot;</span>
        <span>{{reading_time}} min read</span>
    </div>

    <!-- Article content -->
    <article class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-secondary">
        {{{content}}}
    </article>
</main>