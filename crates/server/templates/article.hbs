<section class="flex-1 min-w-0 max-w-prose mx-auto">
    <!-- Top bar -->
    <div class="flex items-center justify-between mb-8">
        <a href="{{#if back_location}}{{back_location}}{{else}}javascript:history.back(){{/if}}" {{#if
            back_location}}hx-boost="true" {{/if}}
            class="flex items-center gap-2 text-sm text-muted hover:text-primary transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back
        </a>
        <div class="flex items-center gap-4">
            <form method="post" action="/do_favourite" hx-post="/do_favourite" hx-target="#main-block"
                hx-swap="morph:innerHtml" hx-vals='{"source": "{{source}}"}' class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="starred" value="{{#unless is_starred}}true{{else}}false{{/unless}}" />
                {{#if is_starred}}
                <button type="submit" class="btn-icon" title="Unstar">
                    <img src="/static/images/FavoriteOn.svg" alt="Unstar" />
                </button>
                {{else}}
                <button type="submit" class="btn-icon" title="Star">
                    <img src="/static/images/FavoriteOff.svg" alt="Star" />
                </button>
                {{/if}}
            </form>
            <form method="post" action="/do_archive" hx-post="/do_archive" hx-target="#main-block"
                hx-swap="morph:innerHtml" hx-vals='{"source": "{{source}}"}' class="flex items-center">
                <input type="hidden" name="article_id" value="{{id}}" />
                <input type="hidden" name="archived" value="{{#unless is_archived}}true{{else}}false{{/unless}}" />
                {{#if is_archived}}
                <button type="submit" class="btn-icon" title="Mark as unread">
                    <img src="/static/images/MarkRead.svg" alt="Mark as unread" />
                </button>
                {{else}}
                <button type="submit" class="btn-icon" title="Mark as read">
                    <img src="/static/images/MarkUnRead.svg" alt="Mark as read" />
                </button>
                {{/if}}
            </form>
            <button type="button" class="btn-icon" title="Edit title" _="on click toggle .hidden on #title-input-form
                   toggle .hidden on #title-text
                   if not #title-input-form.classList.contains('hidden')
                      then call #title-input.focus()">
                <img src="/static/images/Edit.svg" alt="Edit" />
            </button>
            <button type="button" class="btn-icon" title="Delete"
                _="on click
                    set #articleDeleteId.value to '{{id}}'
                    set #articleDeleteSource.value to '{{source}}'
                    call #articleDeleteDialog.showModal()">
                <img src="/static/images/Delete.svg" alt="Delete" />
            </button>
        </div>
    </div>

    <!-- Article header -->
    <h1 class="text-3xl lg:text-4xl font-bold leading-tight mb-4 wrap-break-word">
        <span id="title-text">{{title}}</span>

        <form id="title-input-form" post="/do_edit_title" hx-post="/do_edit_title" hx-target="#main-block"
            hx-swap="morph:innerHtml" hx-vals='{"source": "{{source}}"}' class="hidden w-full">
            <input type="hidden" name="article_id" value="{{id}}" />
            <input id="title-input" type="text" name="title" value="{{title}}"
                class="input-underline w-full text-3xl lg:text-4xl font-bold border-primary" _="on keyup[key=='Enter'] call htmx.trigger(#title-input-form, 'submit')
                   on blur call htmx.trigger(#title-input-form, 'submit')" />
        </form>
    </h1>
    <div class="flex items-center gap-2 text-sm text-muted mb-8 pb-8 border-b border-border">
        <a href="{{url}}" target="_blank" rel="noopener noreferrer"
            class="hover:text-primary transition-colors underline">{{domain}}</a>
        <span>&middot;</span>
        <span>{{reading_time}} min read</span>
    </div>

    <!-- Article content -->
    <article class="prose prose-lg max-w-none prose-headings:text-primary prose-a:text-secondary">
        {{{content}}}
    </article>
</section>

<dialog id="articleDeleteDialog" class="dialog-modal">
    <form method="post" action="/do_delete" hx-post="/do_delete" hx-target="#main-block" hx-swap="morph:outerHTML">
        <input type="hidden" id="articleDeleteId" name="article_id" />
        <input type="hidden" id="articleDeleteSource" name="source" />
        <!-- TODO make this back location dependent -->
        <input type="hidden" name="back_location" value="/" />
        <div class="dialog-body">
            <h2 class="text-lg font-medium text-primary">Delete Article</h2>
            <p class="text-sm text-muted">
                Are you sure you want to delete this article? This action cannot be undone.
            </p>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button" class="btn-outline"
                    _="on click call #articleDeleteDialog.close()">
                    Cancel
                </button>
                <button type="submit" class="btn-danger">
                    Delete
                </button>
            </div>
        </div>
    </form>
</dialog>