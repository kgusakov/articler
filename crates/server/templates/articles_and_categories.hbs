<dialog id="articleDeleteDialog" class="dialog-modal">
    <form method="post" action="/do_delete" hx-post="/do_delete" hx-target="#article-cards"
        hx-swap="morph:innerHTML" id="do_delete_form"
        _="on htmx:afterRequest call #articleDeleteDialog.close()">
        <input type="hidden" id="articleDeleteId" name="article_id" />
        <div class="dialog-body">
            <h2 class="text-lg font-medium text-primary">Delete Article</h2>
            <p class="text-sm text-muted">
                Are you sure you want to delete this article? This action cannot be undone.
            </p>
            <div class="flex justify-end gap-3 pt-2">
                <button type="button" class="btn-outline"
                    _="on click call #articleDeleteDialog.close()">
                    Cancel
                </button>
                <button type="submit" class="btn-danger">
                    Delete
                </button>
            </div>
        </div>
    </form>
</dialog>

<!-- Sidebar -->
<aside id="categories-menu"
    class="w-full lg:w-[348px] lg:pr-8 space-y-1 flex lg:block gap-2 overflow-x-auto lg:overflow-visible"
    hx-swap="morph:innerHTML" hx-get="/partial/categories"
    hx-trigger="htmx:afterRequest from:#do_favourite_form,htmx:afterRequest from:#do_archive_form,htmx:afterRequest from:#do_delete_form">
    {{> categories}}
</aside>

<!-- Content -->
<section class="flex-1">
    <form action="/search" method="get" class="mb-6">
        <div class="input-wrapper focus-within:outline-primary">
            <img src="/static/images/Search.svg" class="shrink-0" />
            <input type="search" name="q" placeholder="Search articles..." class="input-ghost" />
        </div>
    </form>
    <div id="article-cards" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 lg:gap-8">
        {{> article_cards}}
    </div>
</section>