# Contributor: Kirill Gusakov <kgusakov@gmail.com>
# Maintainer: Kirill Gusakov <kgusakov@gmail.com>
pkgname=articler
pkgver=0.1.0
pkgrel=0
pkgdesc="Read-it-later service with wallabag-compatible API "
arch="all"
url="https://github.com/kgusakov/articler"
license="Unlicense"
install="$pkgname.post-install $pkgname.pre-install"
builddir="$srcdir/$pkgname-$pkgver"
source="
        ../../target/release/articler
        ../../target/release/articlerctl
        articler.openrc
        articler.profile
        articler.post-install
        articler.pre-install
        "

package() {
        install -Dm755 "$srcdir"/articler "$pkgdir"/usr/bin/articler
        install -Dm755 "$srcdir"/articlerctl "$pkgdir"/usr/bin/articlerctl
        install -Dm755 "$srcdir"/articler.openrc "$pkgdir"/etc/init.d/articler
        install -Dm644 "$srcdir"/articler.profile "$pkgdir"/etc/conf.d/articler
}
